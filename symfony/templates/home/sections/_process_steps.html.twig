{% set steps = [
    {
        box: 'sb-1',
        delay: '0.3s',
        icon: 'ph ph-calendar-check ph-light ph-4x color--secondary',
        title: 'beaute_inee_index_step1_title',
        text: 'beaute_inee_index_step1_text'
    },
    {
        box: 'sb-2',
        delay: '0.4s',
        icon: 'ph ph-magnifying-glass ph-light ph-4x color--primary',
        title: 'beaute_inee_index_step2_title',
        text: 'beaute_inee_index_step2_text'
    },
    {
        box: 'sb-3',
        delay: '0.5s',
        icon: 'ph ph-list-checks ph-light ph-4x color--saumon',
        title: 'beaute_inee_index_step3_title',
        text: 'beaute_inee_index_step3_text'
    },
    {
        box: 'sb-4',
        delay: '0.6s',
        icon: 'ph ph-recycle ph-light ph-4x color--peche',
        title: 'beaute_inee_index_step4_title',
        text: 'beaute_inee_index_step4_text'
    }
] %}

<section id="process-steps" class="py-6 services-section division">
    <div class="container">
        <div class="sbox-2-wrapper text-center">
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4">
                {% for step in steps %}
                    <div class="col pb-5">
                        <div class="sbox-2 {{ step.box }} wow fadeInUp" data-wow-delay="{{ step.delay }}">
                            <i class="{{ step.icon }}"></i>
                            <div class="sbox-txt">
                                <h5 class="h5-lg">
                                    {{ l(step.title) }}
                                </h5>
                                <p>
                                    {{ l(step.text) }}
                                </p>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
</section>
