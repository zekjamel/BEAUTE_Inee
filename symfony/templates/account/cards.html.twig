{% extends 'account/base.html.twig' %}
{% block title %}Ma carte connectée | Beauté INÉE{% endblock %}
{% block account_content %}<header class="customer-page-header"><div><p class="customer-kicker">Beauté INÉE</p><h1>Ma carte connectée</h1><p class="customer-subtitle">Votre carte centralise votre suivi beauté et vos avantages.</p></div></header>{% if cards is empty %}<section class="customer-panel"><p class="customer-empty">Votre carte apparaîtra ici après confirmation de votre commande.</p></section>{% else %}{% for card in cards %}<section class="customer-panel"><div class="customer-panel-head"><h2>{{ card.externalIdentifier }}</h2><span class="customer-status">{{ card.status }}</span></div><div class="customer-row"><span class="customer-muted">Fournisseur</span><strong>{{ card.provider ?: 'Beauté INÉE' }}</strong></div><div class="customer-row"><span class="customer-muted">Commandée le</span><strong>{{ card.orderedAt ? card.orderedAt|date('d/m/Y') : 'En préparation' }}</strong></div><div class="customer-row"><span class="customer-muted">Activation</span><strong>{{ card.activatedAt ? card.activatedAt|date('d/m/Y') : 'En attente' }}</strong></div></section>{% endfor %}{% endif %}{% endblock %}
