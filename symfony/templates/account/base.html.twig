{% extends 'base.html.twig' %}

{% block body_class %}customers bg--white account-page{% endblock %}

{% block stylesheets %}
    <style>
        .customer-space { display: grid; grid-template-columns: 240px minmax(0, 1fr); max-width: 1250px; min-height: calc(100vh - 120px); margin: 108px auto 64px; padding: 0 24px; font-family: Lato, sans-serif; color: #353535; }
        .customer-sidebar { padding: 30px 20px; background: #f7f5f3; }.customer-brand { display: block; margin-bottom: 38px; color: #2f3031; font-family: Alatsi, sans-serif; font-size: 20px; letter-spacing: .04em; text-decoration: none; }.customer-brand small { display: block; margin-top: 5px; color: #c65a35; font-family: Lato, sans-serif; font-size: 10px; font-weight: 800; letter-spacing: .14em; text-transform: uppercase; }
        .customer-nav { padding: 0; margin: 0; list-style: none; }.customer-nav li + li { margin-top: 4px; }.customer-nav a { display: flex; gap: 12px; align-items: center; padding: 12px 10px; color: #555; font-size: 14px; font-weight: 800; text-decoration: none; }.customer-nav a:hover, .customer-nav a.is-active { background: #c65a35; color: #fff; }.customer-nav i { width: 17px; text-align: center; }.customer-nav .customer-logout { margin-top: 24px; color: #a94d2d; }
        .customer-content { min-width: 0; padding: 34px 38px 50px; background: #fff; }.customer-page-header { display: flex; justify-content: space-between; gap: 25px; align-items: flex-end; margin-bottom: 30px; }.customer-page-header h1 { margin: 0; font-family: Alatsi, sans-serif; font-size: clamp(32px, 4vw, 46px); line-height: 1; }.customer-kicker { margin: 0 0 9px; color: #c65a35; font-size: 11px; font-weight: 800; letter-spacing: .14em; text-transform: uppercase; }.customer-subtitle { margin: 12px 0 0; color: #777; line-height: 1.5; }.customer-panel { margin-bottom: 16px; border: 1px solid #e6ded9; background: #fff; }.customer-panel-head { display: flex; justify-content: space-between; gap: 16px; align-items: center; padding: 20px 22px; border-bottom: 1px solid #eee; }.customer-panel-head h2 { margin: 0; font-family: Alatsi, sans-serif; font-size: 22px; }.customer-muted { color: #777; font-size: 14px; }.customer-status { display: inline-block; color: #a94d2d; font-size: 11px; font-weight: 800; letter-spacing: .09em; text-transform: uppercase; }.customer-row { display: flex; justify-content: space-between; gap: 18px; padding: 16px 22px; border-bottom: 1px solid #f0f0f0; }.customer-row:last-child { border-bottom: 0; }.customer-row strong { display: block; }.customer-empty { margin: 0; padding: 22px; color: #777; }.customer-link { color: #c65a35; font-size: 13px; font-weight: 800; text-decoration: none; }.customer-link:hover { text-decoration: underline; }
        @media (max-width: 850px) { .customer-space { grid-template-columns: 1fr; padding: 0 16px; }.customer-sidebar { display: flex; flex-wrap: wrap; align-items: center; gap: 12px; padding: 18px; }.customer-brand { width: 100%; margin: 0; }.customer-nav { display: flex; flex-wrap: wrap; gap: 4px; }.customer-nav li + li { margin: 0; }.customer-nav .customer-logout { margin-top: 0; }.customer-content { padding: 28px 22px 42px; } }@media (max-width: 600px) { .customer-space { margin-top: 92px; }.customer-page-header { display: block; }.customer-row { display: block; }.customer-row > :last-child { margin-top: 6px; } }
    </style>
    {% block account_stylesheets %}{% endblock %}
{% endblock %}

{% block body %}
    {% set current_route = app.request.attributes.get('_route') %}
    <main class="customer-space"><aside class="customer-sidebar"><a class="customer-brand" href="{{ path('account_dashboard') }}">BEAUTÉ INÉE<small>Mon espace</small></a><ul class="customer-nav"><li><a class="{{ current_route == 'account_dashboard' ? 'is-active' : '' }}" href="{{ path('account_dashboard') }}"><i class="fa fa-house"></i> Vue d’ensemble</a></li><li><a class="{{ current_route == 'account_cards' ? 'is-active' : '' }}" href="{{ path('account_cards') }}"><i class="fa fa-id-card"></i> Ma carte</a></li><li><a class="{{ current_route == 'account_diagnostics' ? 'is-active' : '' }}" href="{{ path('account_diagnostics') }}"><i class="fa fa-wand-magic-sparkles"></i> Mes diagnostics</a></li><li><a class="{{ current_route == 'account_orders' ? 'is-active' : '' }}" href="{{ path('account_orders') }}"><i class="fa fa-bag-shopping"></i> Mes commandes</a></li><li><a class="customer-logout" href="{{ path('app_logout') }}"><i class="fa fa-arrow-right-from-bracket"></i> Se déconnecter</a></li></ul></aside><section class="customer-content">{% block account_content %}{% endblock %}</section></main>
{% endblock %}
