{% extends 'account/base.html.twig' %}
{% block title %}Mes commandes | Beauté INÉE{% endblock %}
{% block account_content %}<header class="customer-page-header"><div><p class="customer-kicker">Historique d’achat</p><h1>Mes commandes</h1><p class="customer-subtitle">Suivez vos commandes et leur statut de paiement.</p></div></header><section class="customer-panel"><div class="customer-panel-head"><h2>Historique</h2><span>{{ orders|length }} commande{{ orders|length > 1 ? 's' : '' }}</span></div>{% if orders is empty %}<p class="customer-empty">Vous n’avez pas encore passé de commande.</p>{% else %}{% for order in orders %}<div class="customer-row"><span><strong>{{ order.reference }}</strong><span class="customer-muted">{{ order.createdAt|date('d/m/Y à H:i') }}</span></span><span><span class="customer-status">{{ order.status }}</span><strong>{{ (order.totalAmountCents / 100)|number_format(2, ',', ' ') }} {{ order.currency }}</strong></span></div>{% endfor %}{% endif %}</section>{% endblock %}
