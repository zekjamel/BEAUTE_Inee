{% extends 'account/base.html.twig' %}
{% block title %}Mes diagnostics | Beauté INÉE{% endblock %}
{% block account_content %}<header class="customer-page-header"><div><p class="customer-kicker">Mon suivi peau</p><h1>Mes diagnostics</h1><p class="customer-subtitle">Vos résultats pour suivre l’évolution de votre peau dans le temps.</p></div></header><section class="customer-panel"><div class="customer-panel-head"><h2>Historique</h2><span>{{ diagnostics|length }} diagnostic{{ diagnostics|length > 1 ? 's' : '' }}</span></div>{% if diagnostics is empty %}<p class="customer-empty">Votre premier diagnostic apparaîtra ici après votre rendez-vous.</p>{% else %}{% for diagnostic in diagnostics %}<div class="customer-row"><span><strong>{{ diagnostic.performedAt|date('d/m/Y') }}</strong><span class="customer-muted">{{ diagnostic.skinType ?: 'Analyse de peau' }}{% if diagnostic.skinConditions %} · {{ diagnostic.skinConditions|join(', ') }}{% endif %}</span></span><span><span class="customer-status">{{ diagnostic.status }}</span><strong>{{ diagnostic.globalScore is not null ? diagnostic.globalScore ~ '/100' : '—' }}</strong></span></div>{% endfor %}{% endif %}</section>{% endblock %}
