{% extends 'base.html.twig' %}

{% block title %}Mon profil | Beauté INÉE{% endblock %}
{% block body_class %}customers bg--white account-page{% endblock %}

{% block stylesheets %}
    <style>
        .profile-page { max-width: 820px; margin: 140px auto 72px; padding: 0 24px; font-family: Lato, sans-serif; color: #353535; }
        .profile-kicker { color: #c65a35; font-weight: 800; font-size: 12px; letter-spacing: .13em; text-transform: uppercase; }
        .profile-card { margin-top: 26px; padding: 34px; border: 1px solid #e6ded9; background: #fff; }
        .profile-card h1 { margin-top: 0; font-family: Alatsi, sans-serif; }
        .profile-row { display: flex; justify-content: space-between; gap: 20px; padding: 15px 0; border-bottom: 1px solid #eee; }
        .profile-row:last-of-type { border-bottom: 0; }
        .profile-label { color: #777; }
        .profile-value { font-weight: 800; text-align: right; }
        .profile-actions { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 28px; }
        .profile-button { display: inline-block; padding: 14px 18px; border: 1px solid #c65a35; background: #c65a35; color: #fff; font-size: 12px; font-weight: 800; letter-spacing: .1em; text-decoration: none; text-transform: uppercase; }
        .profile-button--outline { background: #fff; color: #c65a35; }
        @media (max-width: 560px) { .profile-page { margin-top: 110px; } .profile-row { display: block; } .profile-value { margin-top: 6px; text-align: left; } }
    </style>
{% endblock %}

{% block body %}
    <main class="profile-page">
        <p class="profile-kicker">Profil administrateur</p>
        <section class="profile-card">
            <h1>Mon compte</h1>
            <div class="profile-row"><span class="profile-label">Adresse e-mail</span><span class="profile-value">{{ user.userIdentifier }}</span></div>
            <div class="profile-row"><span class="profile-label">Accès</span><span class="profile-value">Administrateur</span></div>
            <div class="profile-actions">
                <a class="profile-button" href="{{ path('admin_dashboard') }}">Ouvrir l’administration</a>
                <a class="profile-button profile-button--outline" href="{{ path('app_logout') }}">Se déconnecter</a>
            </div>
        </section>
    </main>
{% endblock %}
