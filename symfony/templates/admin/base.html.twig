{% extends 'base.html.twig' %}

{% block body_class %}customers bg--white account-page{% endblock %}

{% block stylesheets %}
    <style>
        .admin-shell { display: grid; grid-template-columns: 260px minmax(0, 1fr); max-width: 1440px; min-height: calc(100vh - 120px); margin: 108px auto 64px; padding: 0 28px; font-family: Lato, sans-serif; color: #2f3031; }
        .admin-sidebar { padding: 30px 22px; background: #25292d; color: #fff; }
        .admin-brand { display: block; margin-bottom: 38px; color: #fff; font-family: Alatsi, sans-serif; font-size: 21px; letter-spacing: .04em; text-decoration: none; }
        .admin-brand small { display: block; margin-top: 5px; color: #e59b7e; font-family: Lato, sans-serif; font-size: 10px; font-weight: 800; letter-spacing: .14em; text-transform: uppercase; }
        .admin-nav-label { margin: 0 0 10px; color: #a9aaac; font-size: 10px; font-weight: 800; letter-spacing: .13em; text-transform: uppercase; }
        .admin-nav { padding: 0; margin: 0; list-style: none; }
        .admin-nav + .admin-nav-label { margin-top: 28px; }
        .admin-nav a { display: flex; gap: 12px; align-items: center; padding: 12px 11px; color: #d9d9d9; font-size: 14px; font-weight: 700; text-decoration: none; }
        .admin-nav a:hover, .admin-nav a.is-active { background: #c65a35; color: #fff; }
        .admin-nav i { width: 17px; text-align: center; }
        .admin-nav .admin-logout { color: #e59b7e; }
        .admin-content { min-width: 0; padding: 34px 38px 50px; background: #fff; }
        .admin-page-header { display: flex; justify-content: space-between; gap: 25px; align-items: flex-end; margin-bottom: 30px; }
        .admin-page-header h1 { margin: 0; font-family: Alatsi, sans-serif; font-size: clamp(32px, 4vw, 46px); line-height: 1; }
        .admin-page-kicker { margin: 0 0 9px; color: #c65a35; font-size: 11px; font-weight: 800; letter-spacing: .14em; text-transform: uppercase; }
        .admin-page-subtitle { margin: 12px 0 0; color: #777; line-height: 1.5; }
        .admin-primary-action { display: inline-flex; align-items: center; gap: 9px; padding: 14px 18px; background: #c65a35; color: #fff; font-size: 12px; font-weight: 800; letter-spacing: .09em; text-decoration: none; text-transform: uppercase; white-space: nowrap; }
        .admin-primary-action:hover { color: #fff; opacity: .88; }
        .admin-panel { border: 1px solid #e6ded9; background: #fff; }
        .admin-panel-head { display: flex; justify-content: space-between; gap: 16px; align-items: center; padding: 20px 22px; border-bottom: 1px solid #eee; }
        .admin-panel-head h2, .admin-panel-head h3 { margin: 0; font-family: Alatsi, sans-serif; font-size: 22px; }
        .admin-muted { color: #777; font-size: 14px; }
        .admin-status { display: inline-block; color: #a94d2d; font-size: 11px; font-weight: 800; letter-spacing: .09em; text-transform: uppercase; }
        .admin-flash { margin: 0 0 20px; padding: 14px 17px; border-left: 3px solid #c65a35; background: #f7f5f3; color: #454545; font-weight: 700; }.admin-flash--error { border-color: #a94d2d; }
        @media (max-width: 980px) { .admin-shell { grid-template-columns: 1fr; padding: 0 16px; } .admin-sidebar { display: flex; flex-wrap: wrap; align-items: center; gap: 12px; padding: 18px; } .admin-brand { width: 100%; margin: 0; } .admin-nav-label { display: none; } .admin-nav { display: flex; flex-wrap: wrap; gap: 4px; } .admin-nav + .admin-nav-label { margin: 0; } .admin-content { padding: 28px 22px 42px; } }
        @media (max-width: 600px) { .admin-shell { margin-top: 92px; } .admin-page-header { display: block; } .admin-primary-action { margin-top: 18px; } }
    </style>
    {% block admin_stylesheets %}{% endblock %}
{% endblock %}

{% block body %}
    {% set current_route = app.request.attributes.get('_route') %}
    <main class="admin-shell">
        <aside class="admin-sidebar">
            <a class="admin-brand" href="{{ path('admin_dashboard') }}">BEAUTÉ INÉE<small>Administration</small></a>
            <p class="admin-nav-label">Pilotage</p>
            <ul class="admin-nav">
                <li><a class="{{ current_route == 'admin_dashboard' ? 'is-active' : '' }}" href="{{ path('admin_dashboard') }}"><i class="fa fa-chart-line"></i> Vue d’ensemble</a></li>
                <li><a class="{{ current_route starts with 'admin_customer_' ? 'is-active' : '' }}" href="{{ path('admin_customer_index') }}"><i class="fa fa-users"></i> Clients</a></li>
                <li><a class="{{ current_route starts with 'admin_order_' ? 'is-active' : '' }}" href="{{ path('admin_order_index') }}"><i class="fa fa-bag-shopping"></i> Commandes</a></li>
                <li><a class="{{ current_route starts with 'admin_card_' ? 'is-active' : '' }}" href="{{ path('admin_card_index') }}"><i class="fa fa-id-card"></i> Cartes connectées</a></li>
                <li><a class="{{ current_route starts with 'admin_quardlock' ? 'is-active' : '' }}" href="{{ path('admin_quardlock') }}"><i class="fa fa-fingerprint"></i> Quardlock</a></li>
                <li><a class="{{ current_route starts with 'admin_diagnostic_' ? 'is-active' : '' }}" href="{{ path('admin_diagnostic_index') }}"><i class="fa fa-wand-magic-sparkles"></i> Diagnostics</a></li>
                <li><a class="{{ current_route starts with 'admin_email_' ? 'is-active' : '' }}" href="{{ path('admin_email_index') }}"><i class="fa fa-envelope"></i> Emails</a></li>
            </ul>
            <p class="admin-nav-label">Compte</p>
            <ul class="admin-nav">
                <li><a href="{{ path('account_dashboard') }}"><i class="fa fa-user"></i> Mon profil</a></li>
                <li><a class="admin-logout" href="{{ path('app_logout') }}"><i class="fa fa-arrow-right-from-bracket"></i> Se déconnecter</a></li>
            </ul>
        </aside>
        <section class="admin-content">{% for message in app.flashes('success') %}<p class="admin-flash">{{ message }}</p>{% endfor %}{% for message in app.flashes('error') %}<p class="admin-flash admin-flash--error">{{ message }}</p>{% endfor %}{% block admin_content %}{% endblock %}</section>
    </main>
{% endblock %}
