{% extends 'admin/base.html.twig' %}

{% block title %}Diagnostic | Administration Beauté INÉE{% endblock %}

{% block admin_stylesheets %}
    <style>
        .admin-back { display: inline-flex; gap: 8px; margin-bottom: 24px; color: #777; font-size: 14px; text-decoration: none; }.admin-back:hover { color: #c65a35; }.diagnostic-grid { display: grid; grid-template-columns: minmax(0, 1.1fr) minmax(290px, .9fr); gap: 16px; }.diagnostic-detail { display: grid; grid-template-columns: 165px minmax(0, 1fr); gap: 14px; padding: 15px 22px; border-bottom: 1px solid #eee; }.diagnostic-detail:last-child { border-bottom: 0; }.diagnostic-detail dt { color: #777; }.diagnostic-detail dd { margin: 0; font-weight: 700; }.diagnostic-list { padding: 10px 22px 19px; margin: 0; }.diagnostic-list li { padding: 7px 0; border-bottom: 1px solid #f0f0f0; }.diagnostic-list li:last-child { border-bottom: 0; } @media (max-width: 900px) { .diagnostic-grid { grid-template-columns: 1fr; } }@media (max-width: 500px) { .diagnostic-detail { grid-template-columns: 1fr; gap: 4px; } }
    </style>
{% endblock %}

{% block admin_content %}
    <a class="admin-back" href="{{ path('admin_diagnostic_index') }}"><i class="fa fa-arrow-left"></i> Retour aux diagnostics</a>
    <header class="admin-page-header"><div><p class="admin-page-kicker">Diagnostic peau</p><h1>{{ diagnostic.performedAt|date('d/m/Y à H:i') }}</h1><p class="admin-page-subtitle">{{ diagnostic.externalReference ?: 'Diagnostic sans référence externe' }}{% if diagnostic.customer %} · <a href="{{ path('admin_customer_show', {id: diagnostic.customer.id}) }}">{{ diagnostic.customer.firstName }} {{ diagnostic.customer.lastName }}</a>{% endif %}</p></div><span class="admin-status">{{ diagnostic.status }}</span></header>
    <section class="diagnostic-grid"><article class="admin-panel"><div class="admin-panel-head"><h2>Résultat</h2>{% if diagnostic.globalScore is not null %}<strong>{{ diagnostic.globalScore }}/100</strong>{% endif %}</div><dl><div class="diagnostic-detail"><dt>Type de peau</dt><dd>{{ diagnostic.skinType ?: 'Non renseigné' }}</dd></div><div class="diagnostic-detail"><dt>État de peau</dt><dd>{{ diagnostic.skinConditions ? diagnostic.skinConditions|join(', ') : 'Non renseigné' }}</dd></div><div class="diagnostic-detail"><dt>Objectifs</dt><dd>{{ diagnostic.priorityObjectives ? diagnostic.priorityObjectives|join(', ') : 'Non renseigné' }}</dd></div><div class="diagnostic-detail"><dt>Réalisé le</dt><dd>{{ diagnostic.performedAt|date('d/m/Y à H:i') }}</dd></div></dl></article><aside><article class="admin-panel"><div class="admin-panel-head"><h2>Client</h2></div>{% if diagnostic.customer %}<dl><div class="diagnostic-detail"><dt>Nom</dt><dd><a href="{{ path('admin_customer_show', {id: diagnostic.customer.id}) }}">{{ diagnostic.customer.firstName }} {{ diagnostic.customer.lastName }}</a></dd></div><div class="diagnostic-detail"><dt>E-mail</dt><dd>{{ diagnostic.customer.email ?: 'Non renseigné' }}</dd></div></dl>{% else %}<p style="padding: 22px; color: #777; margin: 0">Ce diagnostic n’est pas associé à un client.</p>{% endif %}</article><article class="admin-panel" style="margin-top: 16px"><div class="admin-panel-head"><h2>Recommandations</h2></div>{% if diagnostic.recommendations %}<ul class="diagnostic-list">{% for recommendation in diagnostic.recommendations %}<li>{{ recommendation is iterable ? recommendation|json_encode : recommendation }}</li>{% endfor %}</ul>{% else %}<p style="padding: 22px; color: #777; margin: 0">Aucune recommandation disponible.</p>{% endif %}</article></aside></section>
{% endblock %}
