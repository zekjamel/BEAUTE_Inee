{% extends 'admin/base.html.twig' %}

{% block title %}{{ card.externalIdentifier }} | Administration Beauté INÉE{% endblock %}

{% block admin_stylesheets %}
    <style>
        .admin-back { display: inline-flex; gap: 8px; margin-bottom: 24px; color: #777; font-size: 14px; text-decoration: none; }.admin-back:hover { color: #c65a35; }.card-grid { display: grid; grid-template-columns: minmax(0, 1fr) minmax(290px, .8fr); gap: 16px; }.card-detail { display: grid; grid-template-columns: 170px minmax(0, 1fr); gap: 14px; padding: 15px 22px; border-bottom: 1px solid #eee; }.card-detail:last-child { border-bottom: 0; }.card-detail dt { color: #777; }.card-detail dd { margin: 0; font-weight: 700; }.card-actions { display: grid; gap: 9px; padding: 20px 22px; }.card-actions form { margin: 0; }.card-action { width: 100%; padding: 13px; border: 1px solid #c65a35; background: #c65a35; color: #fff; font: inherit; font-size: 12px; font-weight: 800; letter-spacing: .07em; text-align: left; text-transform: uppercase; cursor: pointer; }.card-action:hover { opacity: .88; }@media (max-width: 900px) { .card-grid { grid-template-columns: 1fr; } }@media (max-width: 500px) { .card-detail { grid-template-columns: 1fr; gap: 4px; } }
    </style>
{% endblock %}

{% block admin_content %}
    <a class="admin-back" href="{{ path('admin_card_index') }}"><i class="fa fa-arrow-left"></i> Retour aux cartes</a>
    <header class="admin-page-header"><div><p class="admin-page-kicker">Carte connectée</p><h1>{{ card.externalIdentifier }}</h1><p class="admin-page-subtitle">Statut et rattachement client de la carte Cardlab.</p></div><span class="admin-status">{{ card.status|replace({'_': ' '}) }}</span></header>
    <section class="card-grid"><article class="admin-panel"><div class="admin-panel-head"><h2>Cycle de vie</h2></div><dl><div class="card-detail"><dt>Fournisseur</dt><dd>{{ card.provider ?: 'Non renseigné' }}</dd></div><div class="card-detail"><dt>Commande source</dt><dd>{% if card.sourceOrder %}<a href="{{ path('admin_order_show', {id: card.sourceOrder.id}) }}">{{ card.sourceOrder.reference }}</a>{% else %}Non rattachée{% endif %}</dd></div><div class="card-detail"><dt>Commandée le</dt><dd>{{ card.orderedAt ? card.orderedAt|date('d/m/Y à H:i') : 'Non renseigné' }}</dd></div><div class="card-detail"><dt>Remise au client</dt><dd>{{ card.collectedAt ? card.collectedAt|date('d/m/Y à H:i') : 'En attente' }}</dd></div><div class="card-detail"><dt>Initialisée le</dt><dd>{{ card.initializedAt ? card.initializedAt|date('d/m/Y à H:i') : 'En attente' }}</dd></div><div class="card-detail"><dt>Configurée le</dt><dd>{{ card.configuredAt ? card.configuredAt|date('d/m/Y à H:i') : 'En attente' }}</dd></div><div class="card-detail"><dt>Activée le</dt><dd>{{ card.activatedAt ? card.activatedAt|date('d/m/Y à H:i') : 'Non activée' }}</dd></div></dl></article><aside><article class="admin-panel"><div class="admin-panel-head"><h2>Client associé</h2></div>{% if card.customer %}<dl><div class="card-detail"><dt>Nom</dt><dd><a href="{{ path('admin_customer_show', {id: card.customer.id}) }}">{{ card.customer.firstName }} {{ card.customer.lastName }}</a></dd></div><div class="card-detail"><dt>E-mail</dt><dd>{{ card.customer.email ?: 'Non renseigné' }}</dd></div><div class="card-detail"><dt>Téléphone</dt><dd>{{ card.customer.phone ?: 'Non renseigné' }}</dd></div></dl>{% else %}<p style="padding: 22px; color: #777; margin: 0">Cette carte n’est pas encore associée à un client.</p>{% endif %}</article><article class="admin-panel" style="margin-top: 16px"><div class="admin-panel-head"><h2>Actions en boutique</h2></div>{% if availableTransitions is empty %}<p style="padding: 22px; color: #777; margin: 0">Aucune action disponible pour ce statut.</p>{% else %}<div class="card-actions">{% for status, label in availableTransitions %}<form method="post" action="{{ path('admin_card_transition', {id: card.id, status: status}) }}"><input type="hidden" name="_token" value="{{ csrf_token('card_transition_' ~ card.id) }}"><button class="card-action" type="submit">{{ label }} <i class="fa fa-arrow-right"></i></button></form>{% endfor %}</div>{% endif %}</article></aside></section>
{% endblock %}
