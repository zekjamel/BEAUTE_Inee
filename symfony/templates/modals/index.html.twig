<!-- MODAL-Diag -->
<div id="modal-diagnostic" class="modal fade" tabindex="-1" aria-labelledby="modalDiagnosticLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content position-relative">

            <!-- BOUTON FERMER -->
            <button type="button" class="modal-close color--black ico-20" data-bs-dismiss="modal" aria-label="Close">
                <span class="flaticon-246"></span>
            </button>

            <!-- CONTENU MODAL -->
            <div class="modal-body">
                <div class="container">
                    <div class="row justify-content-center">
                        <div class="col-md-10 py-5 text-center">

                            <!-- ÉTAPE 1 -->
                            <div id="step-1">
                                <h3 id="modalDiagnosticLabel" class="mb-3">
                                    {{ l('modal_diagnostic_title')|raw }}
                                </h3>
                                <p class="mb-4">{{ l('modal_diagnostic_intro') }}</p>
                                <div class="d-flex justify-content-center flex-wrap gap-3">
                                    <button type="button" class="btn btn--tra-black hover--gold" onclick="showStep('non')">
                                        {{ l('modal_diagnostic_no') }}
                                    </button>
                                    <button type="button" class="btn btn--tra-gold hover--gold" onclick="showStep('oui')">
                                        {{ l('modal_diagnostic_yes') }}
                                    </button>
                                </div>
                            </div>

                            <!-- ÉTAPE 2A : pas de diagnostic -->
                            <div id="step-2-non" class="d-none">
                                <h4 class="mt-4 mb-3">{{ l('modal_diagnostic_no_title') }}</h4>
                                <p class="mb-4">{{ l('modal_diagnostic_no_text') }}</p>
                                <div class="d-flex justify-content-center flex-wrap gap-3 mb-3">
                                    <a href="{{ path('app_login') }}" class="btn btn--tra-black hover--gold">
                                        {{ l('modal_diagnostic_create_account') }}
                                    </a>
                                </div>
                                <p class="text-muted"><small>{{ l('modal_diagnostic_no_note') }}</small></p>
                            </div>

                            <!-- ÉTAPE 2B : déjà fait -->
                            <div id="step-2-oui" class="d-none">
                                <h4 class="mt-4 mb-3">{{ l('modal_diagnostic_yes_title') }}</h4>
                                <p class="mb-4">{{ l('modal_diagnostic_yes_text') }}</p>
                                <a href="https://beaute-inee.myshopify.com" class="btn btn--tra-gold hover--gold mb-3">
                                    {{ l('modal_diagnostic_shop') }}
                                </a>
                                <p class="text-muted"><small>{{ l('modal_diagnostic_yes_note') }}</small></p>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
            <!-- /modal-body -->

        </div>
    </div>
</div>

