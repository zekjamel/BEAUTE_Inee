{% extends 'base.html.twig' %}

{% block title %}Simulation checkout carte | Beaute INEE{% endblock %}
{% block body_class %}customers bg--white checkout-simulation{% endblock %}

{% block stylesheets %}
    <style>
        .workflow-page { max-width: 980px; margin: 140px auto 70px; padding: 0 24px; color: #353535; font-family: Lato, sans-serif; }
        .workflow-panel { border: 1px solid #e6ded9; padding: 32px; background: #fff; }
        .workflow-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 18px; }
        .workflow-field { display: grid; gap: 8px; }
        .workflow-field label { font-weight: 700; color: #4b4b4b; }
        .workflow-field input, .workflow-field select { min-height: 48px; border: 1px solid #ddd; padding: 0 14px; font: inherit; }
        .workflow-actions { margin-top: 26px; }
        .workflow-button { border: 0; background: #c65a35; color: #fff; padding: 15px 24px; font-weight: 800; letter-spacing: .12em; text-transform: uppercase; cursor: pointer; }
        .workflow-muted { color: #777; font-size: 17px; line-height: 1.7; }
        @media (max-width: 760px) { .workflow-grid { grid-template-columns: 1fr; } .workflow-page { margin-top: 110px; } }
    </style>
{% endblock %}

{% block body %}
    <main class="workflow-page">
        <p class="section-id">Mode developpement</p>
        <h1>Simuler l'achat d'une carte connectee</h1>
        <p class="workflow-muted">
            Cet ecran remplace Stripe temporairement. Il cree une commande, un paiement en attente et permet ensuite de simuler la confirmation du paiement.
        </p>

        <form class="workflow-panel" method="post" action="{{ path('dev_card_checkout_create') }}">
            <input type="hidden" name="_token" value="{{ csrf_token('dev_card_checkout') }}">

            <div class="workflow-grid">
                <div class="workflow-field">
                    <label for="firstName">Prenom</label>
                    <input id="firstName" name="firstName" value="Layla" required>
                </div>
                <div class="workflow-field">
                    <label for="lastName">Nom</label>
                    <input id="lastName" name="lastName" value="Nidam" required>
                </div>
                <div class="workflow-field">
                    <label for="email">Email</label>
                    <input id="email" name="email" type="email" value="layla.nidam@example.com" required>
                </div>
                <div class="workflow-field">
                    <label for="phone">Telephone</label>
                    <input id="phone" name="phone" value="+33600000000">
                </div>
                <div class="workflow-field">
                    <label for="addressLine1">Adresse</label>
                    <input id="addressLine1" name="addressLine1" value="135 Boulevard Haussmann">
                </div>
                <div class="workflow-field">
                    <label for="postalCode">Code postal</label>
                    <input id="postalCode" name="postalCode" value="75008">
                </div>
                <div class="workflow-field">
                    <label for="city">Ville</label>
                    <input id="city" name="city" value="Paris">
                </div>
                <div class="workflow-field">
                    <label for="country">Pays</label>
                    <select id="country" name="country">
                        <option value="FR">France</option>
                        <option value="BE">Belgique</option>
                        <option value="CH">Suisse</option>
                    </select>
                </div>
            </div>

            <div class="workflow-actions">
                <button class="workflow-button" type="submit">Creer la commande test</button>
            </div>
        </form>
    </main>
{% endblock %}
